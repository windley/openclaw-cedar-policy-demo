// Cedar Schema for OpenClaw Tool Authorization
// This schema defines the entity types, actions, and context used for authorizing
// agent tool executions via the Cedar Policy Decision Point (PDP).

namespace OpenClaw {
  //
  // Entity Types
  //

  // Agent represents an OpenClaw agent instance.
  // Each agent has a unique identifier (agentId or sessionKey).
  entity Agent = {
    // Optional: agent role (e.g., "developer", "operator", "auditor")
    "role"?: String,
    // Optional: security level (e.g., "low", "medium", "high")
    "securityLevel"?: String,
  };

  // SubAgent represents a delegated child agent spawned by a main Agent.
  // SubAgents inherit from Agent but have narrower, explicitly delegated permissions.
  entity SubAgent in [Agent] = {
    // The session key of the agent that created this delegation
    "delegatedBy"?: String,
  };

  // Tool represents an executable tool in the OpenClaw system.
  // Tools are the resources being protected by authorization policies.
  entity Tool = {
    // Tool category (e.g., "file_operation", "shell", "network")
    "category"?: String,
    // Risk level (e.g., "low", "medium", "high", "critical")
    "riskLevel"?: String,
  };

  //
  // Actions
  //

  // ToolExec namespace contains all tool execution actions.
  // Each tool type has a corresponding action (e.g., ToolExec::Bash, ToolExec::Read).
  action "ToolExec::Bash" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Read" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Write" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Edit" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Exec" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Process" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Glob" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::Grep" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  action "ToolExec::ApplyPatch" appliesTo {
    principal: [Agent, SubAgent],
    resource: [Tool],
    context: ToolContext
  };

  //
  // Context Schema
  //

  // ToolContext provides runtime information about the tool execution request.
  // This context can be used in policy conditions to make fine-grained authorization decisions.
  type ToolContext = {
    // Tool call identifier (from LLM)
    "toolCallId": String,

    // Session key (agent session identifier)
    "sessionKey"?: String,

    // File path (for file operation tools: read, write, edit) - optional for TPE queries
    "filePath"?: String,

    // Command string (for exec/bash tools) - optional for TPE queries
    "command"?: String,

    // Delegation attributes (present when request is from a SubAgent)
    // Whether this request is operating under a delegation grant
    "isDelegated"?: Bool,
    // Set of action names the delegation permits (e.g., ["read", "write"])
    "delegatedActions"?: Set<String>,
    // File path glob the delegation permits (e.g., "/tmp/*")
    "delegatedPathPattern"?: String,
    // Command glob the delegation permits (e.g., "git *")
    "delegatedCommandPattern"?: String,
  };
}
